<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Elen Peltola</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <div class="main-container">
    <!-- Taustakoristeet -->
    <div class="background-decorations">
      <div class="deco deco-1">🍃</div>
      <div class="deco deco-2">🌿</div>
      <div class="deco deco-3">🍃</div>
      <div class="deco deco-4">🌿</div>
    </div>

    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-content">
        <div class="hero-text">
          <p class="hero-subtitle">Elen Peltola</p>
          <h1 class="hero-title">
            Elen Peltola
            <span class="highlight"></span>
            nettisivu
          </h1>
          <p class="hero-description">
            Ensimmäinen oma verkkosivu, jonka olen tehnyt ja mitä tule nkäyttämään tulevaisuudessa.
          </p>
          <div class="button-group">
            <button class="btn btn-primary">Aloita nyt</button>
            <button class="btn btn-secondary">Lue lisää</button>
          </div>
        </div>

        <div class="hero-image-wrapper">
          <div class="image-container">
            <img src="https://images.unsplash.com/photo-1512428813834-c702c7702b78?q=80&w=1200&auto=format&fit=crop" alt="Peikonlehti" class="hero-image">
          </div>
          <div class="info-card">
            <p class="info-card-label">Minimalistinen tyyli</p>
            <h2 class="info-card-title">Luonnollinen tunnelma</h2>
            <p class="info-card-text">
              Halusin luoda modernisen ja luonnollisen tyylin sivustolle.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🌿</div>
          <h2 class="feature-title">Työ jota voin käyttää tulevaisuudessa</h2>
          <p class="feature-text">Tapa luoda mahdollisimman hyvä pohja itselleni hyödyntääkseen tulevaisuudessa.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌿</div>
          <h2 class="feature-title">Voin opetella uusia taitoja</h2>
          <p class="feature-text">Opettelemalla uusia koodaustaitoja sekä ymmärtäen omaa työtäni voin luoda mielenkiinotsempia elementtejä.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌿</div>
          <h2 class="feature-title">Mahdollisuus käyttää yritystä varten. (muutaman vuoden jälkee)</h2>
          <p class="feature-text">Jos innostuu jossain vaiheessa yrittäjän toimintaa voin hyödyntää tätä pohjaa myöhemmin.</p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="cta-card">
        <p class="cta-label">Ensimmäisen vuoden opiskelijan tekemä</p>
        <h2 class="cta-title">Kiitän käytitte aikaa tutustumiseen oman työn jalanjälkeeni!</h2>
        <p class="cta-description">
          Lisää pohjia tulossa seuraavien vuosien aikana.
        </p>
        <button class="btn btn-cta">Käytä pohjaa</button>
      </div>
    </section>
  </div>
</body>
</html>
